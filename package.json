{
  "name": "sportplus",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "backend:dev": "npm --prefix backend run dev",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "check:backend": "node --check backend/src/index.js && node --check backend/src/db.js && node --check backend/src/http.js",
    "check": "npm run build && npm run check:backend",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.25.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
